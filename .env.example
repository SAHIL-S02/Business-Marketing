# .env (Place in root for deployed production environments)

# Production MongoDB connection URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/agency?retryWrites=true&w=majority

# Secure JSON Web Token string
JWT_SECRET=super_secret_jwt_signature_key_here

# Whitelist CORS configuration referencing the Vercel deployed frontend domain exactly
FRONTEND_URL=https://your-project.vercel.app
